# Copy to .env for local dev. In Lovable Cloud these values are managed
# automatically by the backend connection — do not overwrite them.
#
# All three are safe to ship in the browser bundle. Row-Level Security
# protects the data; only the service role key is secret.

VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-ref"
